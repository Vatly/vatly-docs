},[210,535,486],{"class":240},[210,537,539],{"class":212,"line":538},12,[210,540,541],{"class":240},"]);\n",[543,544,545],"note",{},"The idempotency key must be a unique string up to 64 characters. We recommend using a UUID v4 to ensure uniqueness.",[173,547,549],{"id":548},"how-it-works","How it works",[551,552,553,557,569],"ol",{},[554,555,556],"li",{},"When you make a request with an idempotency key, our API stores the key along with the response.",[554,558,559,560],{},"If you retry the request with the same key:\n",[561,562,563,566],"ul",{},[554,564,565],{},"If the original request succeeded, we'll return the stored response",[554,567,568],{},"If the original request failed or is still processing, we'll process the request normally",[554,570,571],{},"After 24 hours, idempotency keys expire and are removed from our system.",[173,573,575],{"id":574},"best-practices","Best practices",[178,577,578],{},"Here are some tips for using idempotency effectively:",[551,580,581,588,594,600],{},[554,582,583,587],{},[584,585,586],"strong",{},"Generate unique keys",": Use UUIDs or another method to generate unique keys for each request.",[554,589,590,593],{},[584,591,592],{},"Store keys",": Keep track of idempotency keys alongside your request data.",[554,595,596,599],{},[584,597,598],{},"Set retry policies",": Configure your HTTP client to automatically retry failed requests with the same idempotency key.",[554,601,602,605],{},[584,603,604],{},"Handle errors",": Check error responses to determine if you should retry with the same key.",[173,607,609],{"id":608},"example-retry-implementation","Example retry implementation",[178,611,612],{},"Here's an example of how to implement automatic retries with idempotency:",[201,614,616],{"className":319,"code":615,"filename":321,"language":322,"meta":97,"style":97},"$vatly = new \\Vatly\\API\\VatlyApiClient();\n$vatly->setApiKey('live_your_api_key_here');\n\nfunction createCheckoutWithRetry($vatly, $data) {\n    $idempotencyKey = \\Ramse