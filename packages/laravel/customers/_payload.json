\n",[188,346,347],{"class":190,"line":219},[188,348,223],{"emptyLinePlaceholder":222},[188,350,351],{"class":190,"line":226},[188,352,353],{"class":194},"// Get the Vatly customer ID\n",[188,355,356,358,360,362,365,367],{"class":190,"line":232},[188,357,202],{"class":201},[188,359,206],{"class":205},[188,361,209],{"class":201},[188,363,364],{"class":212},"vatlyId",[188,366,341],{"class":201},[188,368,369],{"class":194}," // string|null\n",[173,371,373],{"id":372},"retrieving-customer-data","Retrieving customer data",[178,375,377],{"className":180,"code":376,"language":182,"meta":183,"style":183},"// Get the full customer object from the Vatly API\n$customer = $user->asVatlyCustomer();\n",[185,378,379,384],{"__ignoreMap":183},[188,380,381],{"class":190,"line":191},[188,382,383],{"class":194},"// Get the full customer object from the Vatly API\n",[188,385,386,388,391,394,396,398,400,403],{"class":190,"line":198},[188,387,202],{"class":201},[188,389,390],{"class":205},"customer ",[188,392,393],{"class":201},"=",[188,395,297],{"class":201},[188,397,206],{"class":205},[188,399,209],{"class":201},[188,401,402],{"class":212},"asVatlyCustomer",[188,404,216],{"class":201},[173,406,408],{"id":407},"how-it-works","How it works",[169,410,411,412,415,416,419],{},"The ",[185,413,414],{},"vatly_id"," column on your billable model stores the Vatly customer identifier. When you call ",[185,417,418],{},"createAsVatlyCustomer()",", it:",[421,422,423,431,437],"ol",{},[424,425,426,427,430],"li",{},"Sends a ",[185,428,429],{},"POST"," request to the Vatly API to create a customer",[424,432,433,434,436],{},"Stores the returned customer ID in the ",[185,435,414],{}," column",[424,438,439],{},"Returns the customer response",[169,441,442,443,445,446,448,449,452],{},"If the user already has a ",[185,444,414],{},", calling ",[185,447,418],{}," will throw a ",[185,450,451],{},"CustomerAlreadyCreatedException",".",[173,454,456],{"id":455},"automatic-customer-creation","Automatic customer creation",[169,458,459],{},"When a user starts a checkout without an existing Vatly customer ID, Vatly creates the customer automatically during the checkout flow. The customer ID is synced back to your application via webhooks.",[169,461,462,463,465],{},"This means you don't need to call ",[185,464,418],{}," before starting a checkout - just redirect the user directly.",[467,468,469],"style",{},"html pre.shiki code .sHwdD, html code.shiki .sHwdD{--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#546E7A;--shiki-default-font-style:italic;--shiki-dark:#676E95;--shiki-dark-font-style:italic}html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html pre.shiki code .sTEyZ, html code.shiki .sTEyZ{--shiki-light:#90A4AE;--shiki-default:#EEFFFF;--shiki-dark:#BABED8}html pre.shiki code .s2Zo4, html code.shiki .s2Zo4{--shiki-light:#6182B8;--shiki-default:#82AAFF;--shiki-dark:#82AAFF}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark