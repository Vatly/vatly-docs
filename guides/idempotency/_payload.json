,541],"note",{},"The idempotency key must be a unique string up to 64 characters. We recommend using a UUID v4 to ensure uniqueness.",[169,543,545],{"id":544},"how-it-works","How it works",[547,548,549,553,565],"ol",{},[550,551,552],"li",{},"When you make a request with an idempotency key, our API stores the key along with the response.",[550,554,555,556],{},"If you retry the request with the same key:\n",[557,558,559,562],"ul",{},[550,560,561],{},"If the original request succeeded, we'll return the stored response",[550,563,564],{},"If the original request failed or is still processing, we'll process the request normally",[550,566,567],{},"After 24 hours, idempotency keys expire and are removed from our system.",[169,569,571],{"id":570},"best-practices","Best practices",[174,573,574],{},"Here are some tips for using idempotency effectively:",[547,576,577,584,590,596],{},[550,578,579,583],{},[580,581,582],"strong",{},"Generate unique keys",": Use UUIDs or another method to generate unique keys for each request.",[550,585,586,589],{},[580,587,588],{},"Store keys",": Keep track of idempotency keys alongside your request data.",[550,591,592,595],{},[580,593,594],{},"Set retry policies",": Configure your HTTP client to automatically retry failed requests with the same idempotency key.",[550,597,598,601],{},[580,599,600],{},"Handle errors",": Check error responses to determine if you should retry with the same key.",[169,603,605],{"id":604},"example-retry-implementation","Example retry implementation",[174,607,608],{},"Here's an example of how to implement automatic retries with idempotency:",[197,610,612],{"className":315,"code":611,"filename":317,"language":318,"meta":93,"style":93},"$vatly = new \\Vatly\\API\\VatlyApiClient();\n$vatly->setApiKey('live_your_api_key_here');\n\nfunction createCheckoutWithRetry($vatly, $data) {\n    $idempotencyKey = \\Ramsey\\Uuid\\Uuid::uuid4()->toString();\n    $maxRetries = 3;\n    $attempt = 0;\n\n    while ($attempt \u003C $maxRetri