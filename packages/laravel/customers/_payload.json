lass":215},"hasVatlyId",[191,343,344],{"class":204},"();",[191,346,347],{"class":197}," // bool\n",[191,349,350],{"class":193,"line":222},[191,351,226],{"emptyLinePlaceholder":225},[191,353,354],{"class":193,"line":229},[191,355,356],{"class":197},"// Get the Vatly customer ID\n",[191,358,359,361,363,365,368,370],{"class":193,"line":235},[191,360,205],{"class":204},[191,362,209],{"class":208},[191,364,212],{"class":204},[191,366,367],{"class":215},"vatlyId",[191,369,344],{"class":204},[191,371,372],{"class":197}," // string|null\n",[177,374,376],{"id":375},"retrieving-customer-data","Retrieving customer data",[182,378,380],{"className":184,"code":379,"language":186,"meta":97,"style":97},"// Get the full customer object from the Vatly API\n$customer = $user->asVatlyCustomer();\n",[188,381,382,387],{"__ignoreMap":97},[191,383,384],{"class":193,"line":194},[191,385,386],{"class":197},"// Get the full customer object from the Vatly API\n",[191,388,389,391,394,397,399,401,403,406],{"class":193,"line":201},[191,390,205],{"class":204},[191,392,393],{"class":208},"customer ",[191,395,396],{"class":204},"=",[191,398,300],{"class":204},[191,400,209],{"class":208},[191,402,212],{"class":204},[191,404,405],{"class":215},"asVatlyCustomer",[191,407,219],{"class":204},[177,409,411],{"id":410},"how-it-works","How it works",[173,413,414,415,418,419,422],{},"The ",[188,416,417],{},"vatly_id"," column on your billable model stores the Vatly customer identifier. When you call ",[188,420,421],{},"createAsVatlyCustomer()",", it:",[424,425,426,434,440],"ol",{},[427,428,429,430,433],"li",{},"Sends a ",[188,431,432],{},"POST"," request to the Vatly API to create a customer",[427,435,436,437,439],{},"Stores the returned customer ID in the ",[188,438,417],{}," column",[427,441,442],{},"Returns the customer response",[173,444,445,446,448,449,451,452,455],{},"If the user already has a ",[188,447,417],{},", calling ",[188,450,421],{}," will throw a ",[188,453,454],{},"CustomerAlreadyCreatedException",".",[177,457,459],{"id":458},"automatic-customer-creation","Automatic customer creation",[173,461,462],{},"When a user starts a checkout without an existing Vatly customer ID, Vatly creates the customer automatically during the checkout flow. The customer ID is synced back to your application via webhooks.",[173,464,465,466,468],{},"This means you don't need to call ",[188,467,421],{}," before starting a checkout - just redirect the user directly.",[470,471,472],"style",{},"html pre.shiki code .sHwdD, html code.shiki .sHwdD{--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#546E7A;--shiki-default-font-style:italic;--shiki-dark:#676E95;--shiki-dark-font-style:italic}html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html pre.shiki code .sTEyZ, html code.shiki .sTEyZ{--shiki-light:#90A4AE;--shiki-default:#EEFFFF;--shiki-dark:#BABED8}html pre.shiki code .s2Zo4, html code.shiki .s2Zo4{--shiki-light:#6182B8;--shiki-default:#82AAFF;--shiki-dark:#82AAFF}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--