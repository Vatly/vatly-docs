ass":244},[214,532,290],{"class":244},[214,534,535],{"class":224},"123e4567-e89b-12d3-a456-426614174000",[214,537,383],{"class":244},[214,539,490],{"class":244},[214,541,543],{"class":216,"line":542},12,[214,544,545],{"class":244},"]);\n",[547,548,549],"note",{},"The idempotency key must be a unique string up to 64 characters. We recommend using a UUID v4 to ensure uniqueness.",[177,551,553],{"id":552},"how-it-works","How it works",[555,556,557,561,573],"ol",{},[558,559,560],"li",{},"When you make a request with an idempotency key, our API stores the key along with the response.",[558,562,563,564],{},"If you retry the request with the same key:\n",[565,566,567,570],"ul",{},[558,568,569],{},"If the original request succeeded, we'll return the stored response",[558,571,572],{},"If the original request failed or is still processing, we'll process the request normally",[558,574,575],{},"After 24 hours, idempotency keys expire and are removed from our system.",[177,577,579],{"id":578},"best-practices","Best practices",[182,581,582],{},"Here are some tips for using idempotency effectively:",[555,584,585,592,598,604],{},[558,586,587,591],{},[588,589,590],"strong",{},"Generate unique keys",": Use UUIDs or another method to generate unique keys for each request.",[558,593,594,597],{},[588,595,596],{},"Store keys",": Keep track of idempotency keys alongside your request data.",[558,599,600,603],{},[588,601,602],{},"Set retry policies",": Configure your HTTP client to automatically retry failed requests with the same idempotency key.",[558,605,606,609],{},[588,607,608],{},"Handle errors",": Check error responses to determine if you should retry with the same key.",[177,611,613],{"id":612},"example-retry-implementation","Example retry implementation",[182,615,616],{},"Here's an example of how to implement automatic retries with idempotency:",[205,618,620],{"className":323,"code":619,"filename":325,"language":326,"meta":101,"style":101},"$vatly = new \\Vatly\\API\\VatlyApiClient