; // string|null\n",[199,336,337,342,359,363,368],{"__ignoreMap":108},[202,338,339],{"class":204,"line":205},[202,340,341],{"class":208},"// Check if the user has a Vatly customer ID\n",[202,343,344,346,348,350,353,356],{"class":204,"line":212},[202,345,216],{"class":215},[202,347,220],{"class":219},[202,349,223],{"class":215},[202,351,352],{"class":226},"hasVatlyId",[202,354,355],{"class":215},"();",[202,357,358],{"class":208}," // bool\n",[202,360,361],{"class":204,"line":233},[202,362,237],{"emptyLinePlaceholder":236},[202,364,365],{"class":204,"line":240},[202,366,367],{"class":208},"// Get the Vatly customer ID\n",[202,369,370,372,374,376,379,381],{"class":204,"line":246},[202,371,216],{"class":215},[202,373,220],{"class":219},[202,375,223],{"class":215},[202,377,378],{"class":226},"getVatlyId",[202,380,355],{"class":215},[202,382,383],{"class":208}," // string|null\n",[188,385,387],{"id":386},"retrieving-customer-data","Retrieving customer data",[193,389,391],{"className":195,"code":390,"language":197,"meta":108,"style":108},"// Get the full customer object from the Vatly API\n$customer = $user->asVatlyCustomer();\n",[199,392,393,398],{"__ignoreMap":108},[202,394,395],{"class":204,"line":205},[202,396,397],{"class":208},"// Get the full customer object from the Vatly API\n",[202,399,400,402,405,408,410,412,414,417],{"class":204,"line":212},[202,401,216],{"class":215},[202,403,404],{"class":219},"customer ",[202,406,407],{"class":215},"=",[202,409,311],{"class":215},[202,411,220],{"class":219},[202,413,223],{"class":215},[202,415,416],{"class":226},"asVatlyCustomer",[202,418,230],{"class":215},[188,420,422],{"id":421},"how-it-works","How it works",[184,424,425,426,429,430,433],{},"The ",[199,427,428],{},"vatly_id"," column on your billable model stores the Vatly customer identifier. When you call ",[199,431,432],{},"createAsVatlyCustomer()",", it:",[435,436,437,445,451],"ol",{},[438,439,440,441,444],"li",{},"Sends a ",[199,442,443],{},"POST"," request to the Vatly API to create a customer",[438,446,447,448,450],{},"Stores the returned customer ID in the ",[199,449,428],{}," column",[438,452,453],{},"Returns the customer response",[184,455,456,457,459,460,462,463,466],{},"If the user already has a ",[199,458,428],{},", calling ",[199,461,432],{}," will throw a ",[199,464,465],{},"CustomerAlreadyCreatedException",".",[188,468,470],{"id":469},"automatic-customer-creation","Automatic customer creation",[184,472,473],{},"When a user starts a checkout without an existing Vatly customer ID, Vatly creates the customer automatically during the checkout flow. The customer ID is synced back to your application via webhooks.",[184,475,476,477,479],{},"This means you don't need to call ",[199,478,432],{}," before starting a checkout - just redirect the user directly.",[481,482,483],"style",{},"html pre.shiki code .sHwdD, html code.shiki .sHwdD{--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#546E7A;--shiki-default-font-style:italic;--shiki-dark:#676E95;--shiki-dark-font-style:italic}html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html pre.shiki code .sTEyZ, html code.shiki .sTEyZ{--shiki-light:#90A4AE;--shiki-default:#EEFFFF;--shiki-dark:#BABED8}html pre.shiki code .s2Zo4, html code.shiki .s2Zo4{--shiki-light:#6182B8;--shiki-default:#82AAFF;--shiki-dark:#82AAFF}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {co