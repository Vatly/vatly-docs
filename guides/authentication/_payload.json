ges/2.laravel",[152,155,158,161,164,167,170],{"title":116,"path":153,"stem":154},"/packages/laravel/readme","3.packages/2.laravel/0.readme",{"title":56,"path":156,"stem":157},"/packages/laravel/customers","3.packages/2.laravel/1.customers",{"title":68,"path":159,"stem":160},"/packages/laravel/checkouts","3.packages/2.laravel/2.checkouts",{"title":76,"path":162,"stem":163},"/packages/laravel/subscriptions","3.packages/2.laravel/3.subscriptions",{"title":84,"path":165,"stem":166},"/packages/laravel/orders","3.packages/2.laravel/4.orders",{"title":38,"path":168,"stem":169},"/packages/laravel/webhooks","3.packages/2.laravel/5.webhooks",{"title":171,"path":172,"stem":173},"Configuration","/packages/laravel/configuration","3.packages/2.laravel/99.configuration",{"title":175,"path":176,"stem":177},"Integrations","/integrations","4.integrations",{"id":179,"title":26,"body":180,"description":376,"extension":377,"links":378,"meta":379,"navigation":380,"path":27,"seo":381,"stem":28,"__hash__":382},"docs/1.guides/4.authentication.md",{"type":181,"value":182,"toc":372},"minimark",[183,188,210,213,236,240,243,285,288,292,295,363,368],[184,185,187],"h2",{"id":186},"api-keys","API keys",[189,190,191,192,196,197,204,205,209],"p",{},"To authenticate with the Vatly API, you need to include your API key in the ",[193,194,195],"code",{},"Authorization"," header of each request. You can obtain your API key from the ",[198,199,203],"a",{"href":200,"rel":201},"https://my.vatly.com",[202],"nofollow","Vatly dashboard"," under ",[206,207,208],"strong",{},"Settings » API",".",[189,211,212],{},"Vatly provides separate API keys for live and test environments:",[214,215,216,227],"ul",{},[217,218,219,222,223,226],"li",{},[206,220,221],{},"Live keys"," are prefixed with ",[193,224,225],{},"live_"," and are used for production requests.",[217,228,229,222,232,235],{},[206,230,231],{},"Test keys",[193,233,234],{},"test_"," and are used for testing and development.",[237,238,239],"note",{},"Use your test API key during development to avoid affecting live data. Switch to your live API key when you're ready to go to production.",[189,241,242],{},"Here's how to authenticate your requests using cURL:",[244,245,250],"pre",{"className":246,"code":247,"filename":248,"language":249,"meta":108,"style":108},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","curl https://api.vatly.com/v1/checkouts \\\n  -H \"Authorization: Bearer live_your_api_key_here\"\n","Example request with API key","bash",[193,251,252,269],{"__ignoreMap":108},[253,254,257,261,265],"span",{"class":255,"line":256},"line",1,[253,258,260],{"class":259},"sBMFI","curl",[253,262,264],{"class":263},"sfazB"," https://api.vatly.com/v1/checkouts",[253,266,268],{"class":267},"sTEyZ"," \\\n",[253,270,272,275,279,282],{"class":255,"line":271},2,[253,273,274],{"class":263},"  -H",[253,276,278],{"class":277},"sMK4o"," \"",[253,280,281],{"class":263},"Authorization: Bearer live_your_api_key_here",[253,283,284],{"class":277},"\"\n",[189,286,287],{},"Always keep your API key safe and never expose it in client-side code or commit it to version control. If you suspect your API key has been compromised, you can regenerate it from the Vatly dashboard.",[184,289,291],{"id":290},"using-an-sdk","Using an SDK",[189,293,294],{},"If you use one of our official SDKs, authentication is straightforward. Simply provide your API key when initializing the client, and the SDK will handle the rest.",[244,296,301],{"className":297,"code":298,"filename":299,"language":300,"meta":108,"style":108},"language-php shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","$vatly = new Vatly\\Api\\VatlyApiClient;\n$vatly->setApiKey('live_your_api_key_here');\n","PHP SDK example","php",[193,302,303,335],{"__ignoreMap":108},[253,304,305,308,311,314,318,321,324,327,329,332],{"class":255,"line":256},[253,306,307],{"class":277},"$",[253,309,310],{"class":267},"vatly ",[253,312,313],{"class":277},"=",[253,315,317],{"class":316},"sbssI"," new",[253,319,320],{"class":267}," Vatly",[253,322,323],{"class":277},"\\",[253,325,326],{"class":267},"Api",[253,328,323],{"class":277},[253,330,331],{"class":259},"VatlyApiClient",[253,333,334],{"class":277},";\n",[253,336,337,339,342,345,349,352,355,358,360],{"class":255,"line":271},[253,338,307],{"class":277},[253,340,341],{"class":267},"vatly",[253,343,344],{"class":277},"->",[253,346,348],{"class":347},"s2Zo4","setApiKey",[253,350,351],{"class":277},"(",[253,353,354],{"class":277},"'",[253,356,357],{"class":263},"live_your_api_key_here",[253,359,354],{"class":277},[253,361,362],{"class":277},");\n",[189,364,365],{},[198,366,367],{"href":23},"Check out our list of first-party SDKs",[369,370,371],"style",{},"html pre.shiki code .sBMFI, html code.shiki .sBMFI{--shiki-light:#E2931D;--shiki-default:#FFCB6B;--shiki-dark:#FFCB6B}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html pre.shiki code .sTEyZ, html code.shiki .sTEyZ{--shiki-light:#90A4AE;--shiki-default:#EEFFFF;--shiki-dark:#BABED8}html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(-