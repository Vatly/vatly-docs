s","3.packages/2.laravel/1.customers",{"title":60,"path":152,"stem":153},"/packages/laravel/checkouts","3.packages/2.laravel/2.checkouts",{"title":68,"path":155,"stem":156},"/packages/laravel/subscriptions","3.packages/2.laravel/3.subscriptions",{"title":76,"path":158,"stem":159},"/packages/laravel/orders","3.packages/2.laravel/4.orders",{"title":38,"path":161,"stem":162},"/packages/laravel/webhooks","3.packages/2.laravel/5.webhooks",{"title":164,"path":165,"stem":166},"Configuration","/packages/laravel/configuration","3.packages/2.laravel/99.configuration",{"title":168,"path":169,"stem":170},"Integrations","/integrations","4.integrations",{"id":172,"title":56,"body":173,"description":484,"extension":485,"links":486,"meta":487,"navigation":229,"path":149,"seo":488,"stem":150,"__hash__":489},"docs/3.packages/2.laravel/1.customers.md",{"type":174,"value":175,"toc":477},"minimark",[176,180,185,321,325,377,381,412,416,427,447,460,464,467,473],[177,178,179],"p",{},"Every billable model can be linked to a Vatly customer. Customers are created automatically by Vatly during checkout and synced to your application via webhooks. You can also create customers explicitly if needed.",[181,182,184],"h2",{"id":183},"creating-a-customer","Creating a customer",[186,187,191],"pre",{"className":188,"code":189,"language":190,"meta":101,"style":101},"language-php shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","// Create a Vatly customer for this user\n$user->createAsVatlyCustomer();\n\n// Create with extra data\n$user->createAsVatlyCustomer([\n    'locale' => 'nl_NL',\n    'metadata' => ['internal_id' => $user->id],\n]);\n","php",[192,193,194,203,224,231,237,251,278,315],"code",{"__ignoreMap":101},[195,196,199],"span",{"class":197,"line":198},"line",1,[195,200,202],{"class":201},"sHwdD","// Create a Vatly customer for this user\n",[195,204,206,210,214,217,221],{"class":197,"line":205},2,[195,207,209],{"class":208},"sMK4o","$",[195,211,213],{"class":21