,544,545,549,561],"ol",{},[546,547,548],"li",{},"When you make a request with an idempotency key, our API stores the key along with the response.",[546,550,551,552],{},"If you retry the request with the same key:\n",[553,554,555,558],"ul",{},[546,556,557],{},"If the original request succeeded, we'll return the stored response",[546,559,560],{},"If the original request failed or is still processing, we'll process the request normally",[546,562,563],{},"After 24 hours, idempotency keys expire and are removed from our system.",[165,565,567],{"id":566},"best-practices","Best practices",[170,569,570],{},"Here are some tips for using idempotency effectively:",[543,572,573,580,586,592],{},[546,574,575,579],{},[576,577,578],"strong",{},"Generate unique keys",": Use UUIDs or another method to generate unique keys for each request.",[546,581,582,585],{},[576,583,584],{},"Store keys",": Keep track of idempotency keys alongside your request data.",[546,587,588,591],{},[576,589,590],{},"Set retry policies",": Configure your HTTP client to automatically retry failed requests with the same idempotency key.",[546,593,594,597],{},[576,595,596],{},"Handle errors",": Check error responses to determine if you should retry with the same key.",[165,599,601],{"id":600},"example-retry-implementation","Example retry implementation",[170,603,604],{},"Here's an example of how to implement automatic retries with idempotency:",[192,606,608],{"className":311,"code":607,"filename":313,"language":314,"meta":198,"style":198},"$vatly = new \\Vatly\\API\\VatlyApiClient();\n$vatly->setApiKey('live_your_api_key_here');\n\nfunction createCheckoutWithRetry($vatly, $data) {\n    $idempotencyKey = \\Ramsey\\Uuid\\Uuid::uuid4()->toString();\n    $maxRetries = 3;\n    $attempt = 0;\n\n    while ($attempt \u003C $maxRetries) {\n        try {\n            return $vatly->checkouts->create($data, [\n                'idempotencyKey' => $idempotencyKey,\n            ]);\n        } catch (\\Vatly\\Exception\\ApiExc